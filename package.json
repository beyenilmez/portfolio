{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "description": "Personal portfolio site for Bedirhan Yenilmez — Vite, React, TypeScript, bilingual EN/TR",
  "license": "AGPL-3.0",
  "type": "module",
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": "^24.15.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:client && pnpm build:server && pnpm prerender && pnpm og-image",
    "build:client": "tsc -b && vite build --outDir dist",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist-server",
    "prerender": "node --experimental-strip-types scripts/prerender.ts",
    "og-image": "tsx scripts/og-image.tsx",
    "gen:favicons": "tsx scripts/gen-favicons.ts",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"scripts/**/*.{ts,tsx}\" \"*.{json,md,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\" \"scripts/**/*.{ts,tsx}\" \"*.{json,md,html}\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "yet-another-react-lightbox": "^3.31.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "satori": "^0.26.0",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-imagetools": "^10.0.0"
  }
}
